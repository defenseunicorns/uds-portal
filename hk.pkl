amends "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["check-added-large-files"] {
        check = "hk util check-added-large-files --maxkb=1024 {{files}}"
        glob = List("**/*")
    }
    ["check-merge-conflict"] {
        check = "hk util check-merge-conflict {{files}}"
        glob = List("**/*")
    }
    ["detect-private-key"] {
        check = "hk util detect-private-key {{files}}"
        glob = List("**/*")
    }
    ["end-of-file-fixer"] = (Builtins.newlines) {
        exclude = List("*.json")
    }
    ["fix-byte-order-marker"] = Builtins.fix_byte_order_marker
    ["trailing-whitespace"] = Builtins.trailing_whitespace
    ["yamllint"] {
        check = "yamllint {{files}} -c .yamllint"
        glob = List("**/*.yml", "**/*.yaml")
    }
    ["golangci-lint"] {
        check = "mkdir -p ui/build && touch ui/build/.ignore-empty && golangci-lint run ./..."
        glob = List("**/*.go", "go.mod", "go.sum")
    }
    ["eslint"] {
        check = "pnpm --dir ui exec eslint ."
        fix = "pnpm --dir ui exec eslint . --fix"
        glob = List("ui/**/*.js", "ui/**/*.jsx", "ui/**/*.ts", "ui/**/*.tsx", "ui/**/*.svelte", "ui/**/*.mjs", "ui/**/*.cjs")
    }
    ["prettier"] {
        check = "pnpm --dir ui exec prettier --check ."
        fix = "pnpm --dir ui exec prettier --write ."
        glob = List("ui/**/*.js", "ui/**/*.jsx", "ui/**/*.ts", "ui/**/*.tsx", "ui/**/*.svelte", "ui/**/*.html", "ui/**/*.css", "ui/**/*.md", "ui/**/*.json", "ui/**/*.yaml", "ui/**/*.yml")
    }
    ["svelte-check"] {
        check = "pnpm --dir ui run svcheck"
        glob = List("ui/**/*.svelte", "ui/**/*.ts", "ui/**/*.js")
    }
    ["license-check"] {
        check = "uds run lint:license"
        fix = "uds run lint:fix-license"
    }
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps {
            ...linters
        }
    }
    ["check"] {
        steps {
            ...linters
        }
    }
    ["fix"] {
        fix = true
        steps {
            ...linters
        }
    }
}
