{
  "name": "uds-portal",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later OR LicenseRef-Defense-Unicorns-Commercial",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "svelte-kit sync",
    "test": "pnpm run test:e2e && pnpm run test:unit",
    "lint": "pnpm run lint:all",
    "lint:all": "pnpm run lint:fix && pnpm run eslint && pnpm run svcheck",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "eslint": "eslint .",
    "svcheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "svcheck:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check": "pnpm run svcheck",
    "check:watch": "pnpm run svcheck:watch",
    "format": "pnpm run lint:fix",
    "test:e2e": "TEST_CFG=default playwright test",
    "test:e2e-local": "TEST_CFG=local playwright test",
    "test:install": "playwright install",
    "test:watch": "vitest",
    "test:unit": "vitest --run"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fontsource/inter": "5.2.8",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@kubernetes/client-node": "1.4.0",
    "@playwright/test": "1.60.0",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.62.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.3.1",
    "@types/node": "25.9.1",
    "autoprefixer": "10.5.0",
    "carbon-icons-svelte": "13.11.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-svelte": "3.19.0",
    "flowbite": "4.0.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "kubernetes-fluent-client": "3.11.7",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "4.1.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "svelte": "5.56.1",
    "svelte-check": "4.5.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.5.1",
  "type": "module"
}
